# Root .gitignore for monorepo structure

# Ignore everything at root
*

# Keep frontend and all its contents
!frontend/
!frontend/**/*

# Keep backend and all its contents
!backend/
!backend/**/*

# Keep root-level configs
!.gitignore
!README.md
!PROJECT_STATUS.md
!QUICKSTART.md

# Ignore IDE and tool configs at root
.vscode/
.idea/
*.swp
*.swo
