venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*.local

# Data
data/*.db
data/*.sqlite
*.db

# Logs
*.log
logs/

